# ============================================================
# RAG QA System - Docker 环境配置模板
# 复制此文件为 .env 后按实际环境修改
# ============================================================

# ---- 应用配置 ----
APP_NAME=RAG QA System
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# ---- 数据目录（容器内路径）----
UPLOAD_DIR=data/uploads
PARSED_DIR=data/parsed
DOCUMENT_DB_PATH=data/documents/documents.db
LOG_DIR=data/logs
IMAGE_DIR=data/images
MINERU_DEBUG_DIR=data/mineru_debug
VISION_DEBUG_DIR=data/vision_debug

# ---- 向量数据库 - Milvus（宿主机或外部服务）----
VECTOR_BACKEND=milvus
VECTOR_COLLECTION=rag_chunks
MILVUS_URI=http://host.docker.internal:19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_TOKEN=
MILVUS_DATABASE=default
MILVUS_DIM=1024
MILVUS_NPROBE=64
HYBRID_SEARCH_ENABLED=true
HYBRID_RRF_K=30
HYBRID_DENSE_WEIGHT=0.9
HYBRID_KEYWORD_WEIGHT=0.1

# ---- Redis（外部服务，默认访问宿主机 Redis）----
REDIS_URL=redis://host.docker.internal:6379/0

# ---- Embedding 模型 ----
EMBEDDING_MODEL_NAME=/models/embedding/BGE-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=16
TOP_K=10
CHUNK_SIZE=700
CHUNK_OVERLAP=120
RECALL_CANDIDATE_COUNT=100

# ---- Rerank 模型 ----
RERANK_ENABLED=true
RERANK_MODEL_NAME=/models/rerank/bge-reranker-base
RERANK_BATCH_SIZE=8

# ---- Prompt 配置 ----
PROMPT_CHUNK_CHAR_LIMIT=1200
PROMPT_MAX_CONTEXT_CHARS=6000
QUERY_REWRITE_ENABLED=true

# ---- LLM API 配置 ----
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_API_KEY=请改成你的真实密钥
LLM_MODEL=Pro/deepseek-ai/DeepSeek-V3.2
LLM_TIMEOUT=60
LLM_MAX_TOKENS=1200
LLM_TEMPERATURE=0.2

# ---- 视觉模型配置 ----
VISION_ENABLED=true
VISION_MODEL=Qwen/Qwen3-VL-32B-Instruct
VISION_MAX_WORKERS=10
VISION_MAX_IMAGES_PER_PDF=60
VISION_MIN_IMAGE_WIDTH=120
VISION_MIN_IMAGE_HEIGHT=120
VISION_MAX_TOKENS=500
VISION_DEBUG_SAVE_IMAGES=true
VISION_EXTRACT_VECTOR_DIAGRAMS=true
VISION_MIN_VECTOR_DRAWINGS=8
VISION_RENDER_ZOOM=2.0

# ---- 语音配置 ----
SPEECH_ENABLED=true
SPEECH_MODEL=FunAudioLLM/SenseVoiceSmall

# ---- 水印过滤 ----
WATERMARK_PATTERN_LIST=八维教育,人工智能刘敏,rengongzhinengliumin

# ---- MySQL 配置（宿主机或外部服务）----
MYSQL_HOST=10.223.11.19
MYSQL_PORT=3306
MYSQL_USER=cs
MYSQL_PASSWORD=123456
MYSQL_DATABASE=rag_gd
MYSQL_CHARSET=utf8mb4

# ---- 认证配置 ----
AUTH_SECRET_KEY=请改成更复杂的随机字符串
AUTH_COOKIE_NAME=rag_gd_session
AUTH_TOKEN_TTL_HOURS=12
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# ---- PDF 解析配置 ----
PDF_PARSER_BACKEND=mineru
MINERU_API_MODE=self_hosted
MINERU_API_BASE_URL=https://your-mineru-host/api
MINERU_API_TOKEN=请改成你的真实 token
MINERU_MAX_PAGES_PER_FILE=200
MINERU_REQUEST_TIMEOUT_SECONDS=600
MINERU_POLL_TIMEOUT_SECONDS=1800
