APP_NAME=RAG QA System
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

UPLOAD_DIR=data/uploads
PARSED_DIR=data/parsed
DOCUMENT_DB_PATH=data/documents/documents.db
LOG_DIR=data/logs

VECTOR_BACKEND=milvus
VECTOR_COLLECTION=rag_chunks
MILVUS_URI=http://127.0.0.1:19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_TOKEN=

EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DEVICE=cuda
EMBEDDING_BATCH_SIZE=16
TOP_K=5
CHUNK_SIZE=700
CHUNK_OVERLAP=120
RECALL_CANDIDATE_COUNT=60
HYBRID_SEARCH_ENABLED=true
HYBRID_RRF_K=60
RERANK_ENABLED=true

LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT=60
LLM_MAX_TOKENS=1200
LLM_TEMPERATURE=0.2
VISION_ENABLED=false
VISION_MODEL=
VISION_MAX_WORKERS=4
VISION_MAX_IMAGES_PER_PDF=60
VISION_MIN_IMAGE_WIDTH=120
VISION_MIN_IMAGE_HEIGHT=120
VISION_MAX_TOKENS=500
VISION_DEBUG_SAVE_IMAGES=false
VISION_DEBUG_DIR=data/vision_debug
VISION_EXTRACT_VECTOR_DIAGRAMS=true
VISION_MIN_VECTOR_DRAWINGS=8
VISION_RENDER_ZOOM=2.0
PROMPT_CHUNK_CHAR_LIMIT=400
STREAM_EMIT_INTERVAL_MS=60
STREAM_EMIT_CHAR_THRESHOLD=24

SPEECH_ENABLED=true
SPEECH_MODEL=whisper-1

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=rag_gd
MYSQL_CHARSET=utf8mb4

AUTH_SECRET_KEY=change-this-secret-key
AUTH_COOKIE_NAME=rag_gd_session
AUTH_TOKEN_TTL_HOURS=12
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

WATERMARK_PATTERNS=йҸҲе“„зҳ‘,жө е‘¬з·өйҚҗе‘ҙе„ҙжөЈи·Ёж•Ө,Confidential,йҗ—е ҹжҪҲйҺөвӮ¬йҸҲ?йҚҗе‘ҙе„ҙз’§еӢ¬жһЎ
